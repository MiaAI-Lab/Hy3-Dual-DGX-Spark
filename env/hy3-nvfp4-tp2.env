# Hy3-295B NVFP4-W4A16 · 2x DGX Spark (GB10) · TP=2 over 200G fabric
MODEL_PATH=/models/hy3-nvfp4-w4a16          # bind-mounted from ~/models/hy3-nvfp4-w4a16
SERVED_NAME=hy3
PORT=8600
IMAGE=vllm-node-tf5-glm52-b12x:probe-modded  # vLLM 0.23.1rc1.dev190 (2026-07-04), TF5
HEAD_IP=192.168.192.1                        # Bluey (fabric)
WORKER_IP=192.168.192.2                      # Reddie (fabric)
TP=2
MAX_LEN=131072                               # start conservative; raise after stable (KV: ~0.33MB/tok bf16)
KV_DTYPE=fp8_e4m3                            # frees room toward 256K later
GPU_MEM_UTIL=0.90
MAX_NUM_SEQS=6                               # Tony: 1-stream smoke + 6-way concurrency off the same serve
# MTP speculative decoding (kodelow: 83.4% acceptance, lossless)
SPEC_CONFIG='{"method":"mtp","num_speculative_tokens":1}'
# GB10/sm121: native FP4 MoE kernels have gaps -> force MARLIN (LibertAI-verified)
MOE_BACKEND=marlin
ENFORCE_EAGER=1                              # LibertAI flag for first bring-up; try graphs later (Fable)
